# VLE deployment — environment template.
#
# Copy this file to deploy/.env and fill in real values:
#     cp deploy/.env.example deploy/.env
#
# deploy/.env is gitignored. Never commit it.

# ---- Networking ------------------------------------------------------------

# Public hostname. The reverse proxy (Traefik) will route requests for this
# host to JupyterHub. Must resolve to the server's public IP.
DOMAIN=vle.example.com

# Name of the pre-existing external Docker network that the reverse proxy
# lives on. The compose file attaches JupyterHub to this network so Traefik
# can reach it. Create it once with:
#     docker network create web
TRAEFIK_NETWORK=web

# ---- Authentication --------------------------------------------------------

# "cloudflare" (production): trust the Cf-Access-Authenticated-User-Email
#   header set by Cloudflare Access. Only safe if the hub is unreachable
#   except through the Cloudflare -> reverse-proxy path.
# "dummy" (local dev): accept any username/password. NEVER use on a public
#   host.
AUTH_MODE=cloudflare

# Your Cloudflare Access team domain, e.g. acme.cloudflareaccess.com.
# Used by the hub config for log messages and any future JWT verification.
# Leave as a placeholder if AUTH_MODE=dummy.
CF_ACCESS_TEAM_DOMAIN=example.cloudflareaccess.com

# Email address granted JupyterHub admin privileges. Must match the email
# that Cloudflare Access reports for you.
JUPYTERHUB_ADMIN_EMAIL=admin@example.com

# ---- Cloudflare Tunnel (optional) ------------------------------------------

# If set, the compose stack also starts a `cloudflared` container that
# terminates a Cloudflare Tunnel and forwards to Traefik over the internal
# `web` network. This lets you run without exposing any public ports on the
# host. Leave empty if you terminate TLS / ingress yourself.
# Create the tunnel in the Cloudflare Zero Trust dashboard and paste the
# connector token here.
CLOUDFLARED_TUNNEL_TOKEN=

# ---- Per-user notebook resource limits -------------------------------------

# Memory ceiling for each user's notebook container. Docker syntax: 512m, 1g.
CONTAINER_MEM_LIMIT=512m

# CPU ceiling for each user's notebook container. Fractional cores allowed.
CONTAINER_CPU_LIMIT=0.5

# How long a user's server can sit idle before the culler stops it.
IDLE_TIMEOUT_MINUTES=15

# ---- Images ----------------------------------------------------------------

# Tag to apply to the single-user notebook image. DockerSpawner uses this tag
# when launching per-user containers, so it must match whatever is built from
# deploy/docker/Dockerfile.notebook.
NOTEBOOK_IMAGE=vle-notebook:latest

# ---- Component database (optional) -----------------------------------------

# Path to the SQLite component database INSIDE the spawned container.
# Defaults (set by Dockerfile.notebook) to /home/jovyan/work/data/components.db
# so users get their own editable copy seeded from the image at first login.
# Override only if you mount the DB from a different path.
# VLE_DB_PATH=/home/jovyan/work/data/components.db
